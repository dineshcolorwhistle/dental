// Dental Lab Management System — Core Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  OWNER
  ADMIN
  TECHNICIAN
  DELIVERY
  DOCTOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum WorkOrderStatus {
  CREATED
  ASSIGNED
  IN_PROGRESS
  INTERNAL_VERIFICATION
  EXTERNAL_VERIFICATION
  COMPLETED
  FAILED
  CANCELLED
}

enum ProcessStatus {
  NOT_STARTED
  IN_PROGRESS
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum Language {
  EN
  ES
}


// ─── Tenant ──────────────────────────────────────────────

model Tenant {
  id          String       @id @default(uuid())
  name        String
  subdomain   String       @unique
  status      TenantStatus @default(ACTIVE)
  logoUrl     String?      @map("logo_url")
  contactEmail String?     @map("contact_email")
  contactPhone String?     @map("contact_phone")
  address     String?
  maxOwners   Int          @default(1) @map("max_owners")
  maxAdmins   Int          @default(3) @map("max_admins")
  maxTechnicians Int          @default(6) @map("max_technicians")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // Relations
  branches        Branch[]
  users           User[]
  settings        TenantSettings?
  doctors         Doctor[]
  clinics         Clinic[]
  prosthesisTypes ProsthesisType[]
  processes       Process[]
  processAreas    ProcessArea[]
  workOrders      WorkOrder[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  inventoryItems  InventoryItem[]
  inventoryCategories InventoryCategory[]
  expenseCategories ExpenseCategory[]
  expenses          Expense[]
  apiKeys           ApiKey[]
  conversations     Conversation[]

  @@map("tenants")
}

model TenantSettings {
  id             String @id @default(uuid())
  tenantId       String @unique @map("tenant_id")
  timezone       String @default("UTC")
  dateFormat     String @default("DD/MM/YYYY") @map("date_format")
  currency       String @default("INR")
  workingDays    String @default("Mon,Tue,Wed,Thu,Fri,Sat") @map("working_days")
  workingHoursStart String @default("09:00") @map("working_hours_start")
  workingHoursEnd   String @default("18:00") @map("working_hours_end")
  features       Json   @default("{}")
  defaultLanguage Language @default(ES) @map("default_language")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

// ─── Branch ──────────────────────────────────────────────

model Branch {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  code        String
  address     String?
  phone       String?
  email       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users           User[]
  defaultAdminId  String?          @map("default_admin_id")
  defaultAdmin    User?            @relation("BranchDefaultAdmin", fields: [defaultAdminId], references: [id], onDelete: SetNull)
  doctors         Doctor[]
  clinics         Clinic[]
  prosthesisTypes ProsthesisType[]
  processes       Process[]
  processAreas    ProcessArea[]
  workOrders      WorkOrder[]
  inventoryItems  InventoryItem[]
  expenses        Expense[]
  apiKeys         ApiKey[]

  @@unique([tenantId, code])
  @@map("branches")
}

// ─── User ────────────────────────────────────────────────

model User {
  id            String     @id @default(uuid())
  tenantId      String?    @map("tenant_id")
  branchId      String?    @map("branch_id")
  email         String
  passwordHash  String     @map("password_hash")
  firstName     String     @map("first_name")
  lastName      String     @map("last_name")
  phone         String?
  role          UserRole
  status        UserStatus @default(ACTIVE)
  avatarUrl     String?    @map("avatar_url")
  lastLoginAt   DateTime?  @map("last_login_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  preferredLanguage Language @default(ES) @map("preferred_language")

  // Relations
  tenant              Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch              Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  defaultAdminBranches Branch[]            @relation("BranchDefaultAdmin")
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  defaultTechnicianProcesses Process[]     @relation("ProcessDefaultTechnician")
  createdWorkOrders   WorkOrder[]          @relation("WorkOrderCreatedBy")
  assignedWoProcesses WorkOrderProcess[]   @relation("WoProcessTechnician")
  notifications       Notification[]
  initiatedReworks    ReworkLog[]          @relation("ReworkInitiator")
  technicianReworks   ReworkLog[]          @relation("ReworkTechnician")
  initiatedRepetitions RepetitionLog[]     @relation("RepetitionInitiator")
  pushSubscriptions   PushSubscription[]
  conversationParticipants  ConversationParticipant[]
  sentMessages              Message[]              @relation("MessageSender")
  createdConversations      Conversation[]         @relation("ConversationCreatedBy")
  messageReadReceipts       MessageReadReceipt[]
  doctor                    Doctor?                @relation("DoctorUser")
  workOrderNotes            WorkOrderNote[]
  resolvedVerifications     WorkOrderProcess[]     @relation("VerificationResolvedBy")

  @@unique([email, tenantId, role])
  @@map("users")
}

// ─── Refresh Token ───────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── Password Reset Token ────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─── Doctor ──────────────────────────────────────────────

model Doctor {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  branchId     String?  @map("branch_id")
  clinicId     String?  @map("clinic_id")
  externalId   String?  @map("external_id")
  name         String
  clinicName   String?  @map("clinic_name")
  email        String?
  phone        String?
  address      String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  userId       String?  @unique @map("user_id")

  // Relations
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  clinic     Clinic?     @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  user       User?       @relation("DoctorUser", fields: [userId], references: [id], onDelete: SetNull)
  workOrders WorkOrder[]

  @@map("doctors")
}

model Clinic {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  branchId   String   @map("branch_id")
  name       String   @map("name")
  url        String   @map("url")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  doctors    Doctor[]

  @@unique([branchId, url])
  @@map("clinics")
}

// ─── Prosthesis Type ──────────────────────────────────────

model ProsthesisType {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  branchId    String?  @map("branch_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant             Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch             Branch?                 @relation(fields: [branchId], references: [id], onDelete: SetNull)
  processAssignments ProsthesisTypeProcess[]
  workOrders         WorkOrder[]

  @@unique([tenantId, branchId, name])
  @@map("prosthesis_types")
}

// ─── Process ─────────────────────────────────────────────

model Process {
  id                  String   @id @default(uuid())
  tenantId            String   @map("tenant_id")
  branchId            String?  @map("branch_id")
  name                String
  processArea         String   @map("process_area") // e.g. "Scanning", "Design", "Milling", "QC"
  processAreaId       String?  @map("process_area_id")
  defaultTechnicianId String   @map("default_technician_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  tenant                    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch                    Branch?                 @relation(fields: [branchId], references: [id], onDelete: SetNull)
  processAreaRelation       ProcessArea?            @relation(fields: [processAreaId], references: [id], onDelete: SetNull)
  defaultTechnician         User                    @relation("ProcessDefaultTechnician", fields: [defaultTechnicianId], references: [id], onDelete: Cascade)
  prosthesisTypeAssignments ProsthesisTypeProcess[]

  @@map("processes")
}

// ─── Process Area ────────────────────────────────────────

model ProcessArea {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  branchId    String?  @map("branch_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  processes Process[]

  @@unique([tenantId, branchId, name])
  @@map("process_areas")
}

// ─── Prosthesis Type ↔ Process (Junction) ────────────────

model ProsthesisTypeProcess {
  id               String   @id @default(uuid())
  prosthesisTypeId String   @map("prosthesis_type_id")
  processId        String   @map("process_id")
  sequence         Int      @default(0)
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  prosthesisType ProsthesisType @relation(fields: [prosthesisTypeId], references: [id], onDelete: Cascade)
  process        Process        @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@unique([prosthesisTypeId, processId])
  @@map("prosthesis_type_processes")
}

// ─── Work Order ──────────────────────────────────────────

model WorkOrder {
  id                     String          @id @default(uuid())
  tenantId               String          @map("tenant_id")
  branchId               String?         @map("branch_id")
  folioNumber            String          @map("folio_number")
  fileNumber             String?         @map("file_number")
  doctorId               String          @map("doctor_id")
  patient                String
  boxNumber              String?         @map("box_number")
  prosthesisTypeId       String          @map("prosthesis_type_id")
  specification          String?
  color                  String          @default("A1")
  notes                  String?
  totalQuote             Float?          @map("total_quote")
  initialPayment         Float?          @map("initial_payment")
  paymentReferenceNumber String?         @map("payment_reference_number")
  qrToken                String          @unique @default(uuid()) @map("qr_token")
  status                 WorkOrderStatus @default(CREATED)
  repetitionCount        Int             @default(0) @map("repetition_count")
  createdById            String          @map("created_by_id")
  isExternal             Boolean         @default(false) @map("is_external")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")

  // Relations
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  doctor         Doctor             @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  prosthesisType ProsthesisType     @relation(fields: [prosthesisTypeId], references: [id], onDelete: Cascade)
  createdBy      User               @relation("WorkOrderCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  processes      WorkOrderProcess[]
  reworkLogs     ReworkLog[]
  repetitionLogs RepetitionLog[]
  conversation   Conversation?
  notesList      WorkOrderNote[]

  @@unique([tenantId, folioNumber])
  @@map("work_orders")
}

// ─── Work Order Note ─────────────────────────────────────

model WorkOrderNote {
  id          String   @id @default(uuid())
  workOrderId String   @map("work_order_id")
  authorId    String   @map("author_id")
  content     String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("work_order_notes")
}

// ─── Work Order Process ──────────────────────────────────

model WorkOrderProcess {
  id             String   @id @default(uuid())
  workOrderId    String   @map("work_order_id")
  processName    String   @map("process_name")
  technicianId   String?  @map("technician_id")
  sequence       Int      @default(0)
  isVerification Boolean       @default(false) @map("is_verification")
  status         ProcessStatus @default(NOT_STARTED)
  startedAt      DateTime?     @map("started_at")
  endedAt        DateTime?     @map("ended_at")
  lastPausedAt   DateTime?     @map("last_paused_at")
  pauseCount     Int           @default(0) @map("pause_count")
  totalPauseDuration Int       @default(0) @map("total_pause_duration")
  totalActiveDuration Int      @default(0) @map("total_active_duration")
  verificationStatus String?     @map("verification_status")
  externalDoctorStatus String?   @map("external_doctor_status")
  externalDoctorNotes  String?   @map("external_doctor_notes")
  externalDoctorSubmittedAt DateTime? @map("external_doctor_submitted_at")
  verificationResolvedById String?  @map("verification_resolved_by_id")
  reworkCount    Int           @default(0) @map("rework_count")
  reworkActive   Boolean       @default(false) @map("rework_active")
  createdAt      DateTime      @default(now()) @map("created_at")

  // Relations
  workOrder              WorkOrder            @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  technician             User?                @relation("WoProcessTechnician", fields: [technicianId], references: [id], onDelete: SetNull)
  verificationResolvedBy User?                @relation("VerificationResolvedBy", fields: [verificationResolvedById], references: [id], onDelete: SetNull)
  activityLogs           ProcessActivityLog[]

  @@map("work_order_processes")
}

enum ProcessActivityAction {
  START
  PAUSE
  RESUME
  END
}

model ProcessActivityLog {
  id                 String                @id @default(uuid())
  workOrderProcessId String                @map("work_order_process_id")
  action             ProcessActivityAction
  timestamp          DateTime              @default(now()) @map("timestamp")
  notes              String?               @map("notes")

  // Relations
  workOrderProcess   WorkOrderProcess      @relation(fields: [workOrderProcessId], references: [id], onDelete: Cascade)

  @@map("process_activity_logs")
}

// ─── Notification ────────────────────────────────────────

model Notification {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  userId      String   @map("user_id")
  title       String
  message     String
  type        String   @default("INFO")
  referenceId String?  @map("reference_id")
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── Audit Log ──────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  userId       String?  @map("user_id")
  userEmail    String?  @map("user_email")
  action       String
  entityName   String   @map("entity_name")
  entityId     String   @map("entity_id")
  details      String
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model ReworkLog {
  id                 String    @id @default(uuid())
  workOrderId        String    @map("work_order_id")
  processName        String    @map("process_name")
  reworkCount        Int       @map("rework_count")
  initiatedById      String    @map("initiated_by_id")
  initiatedAt        DateTime  @default(now()) @map("initiated_at")
  verificationStage  String    @map("verification_stage")
  technicianId       String?   @map("technician_id")
  completedAt        DateTime? @map("completed_at")
  approvedAt         DateTime? @map("approved_at")
  status             String    @default("Pending") // "Pending", "In Progress", "Completed", "Approved"
  createdAt          DateTime  @default(now()) @map("created_at")

  // Relations
  workOrder          WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  initiatedBy        User      @relation("ReworkInitiator", fields: [initiatedById], references: [id])
  technician         User?     @relation("ReworkTechnician", fields: [technicianId], references: [id], onDelete: SetNull)

  @@map("rework_logs")
}

model RepetitionLog {
  id                 String    @id @default(uuid())
  workOrderId        String    @map("work_order_id")
  repetitionCount    Int       @map("repetition_count")
  initiatedById      String    @map("initiated_by_id")
  initiatedAt        DateTime  @default(now()) @map("initiated_at")
  verificationStage  String    @map("verification_stage")
  completedSteps     String    @map("completed_steps")
  createdAt          DateTime  @default(now()) @map("created_at")

  // Relations
  workOrder          WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  initiatedBy        User      @relation("RepetitionInitiator", fields: [initiatedById], references: [id])

  @@map("repetition_logs")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  auth      String
  p256dh    String
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model InventoryCategory {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  status      String   @default("active")
  productType String   @default("for_use") @map("product_type") // e.g. "for_use", "for_sale"
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItems InventoryItem[]

  @@unique([tenantId, name])
  @@map("inventory_categories")
}

model InventoryItem {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  branchId        String?  @map("branch_id")
  name            String
  sku             String
  categoryId      String   @map("category_id")
  status          String   // e.g. "IN_STOCK", "LOW_STOCK", "OUT_OF_STOCK", "DISCONTINUED"
  currentQuantity Int      @default(0) @map("current_quantity")
  minQuantity     Int      @default(5) @map("min_quantity")
  unitPrice       Float    @map("unit_price")
  brand           String?
  supplier        String?
  expiryDate      DateTime? @map("expiry_date")
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  category InventoryCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@unique([tenantId, branchId, sku])
  @@map("inventory_items")
}

model ExpenseCategory {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@unique([tenantId, name])
  @@map("expense_categories")
}

model Expense {
  id            String          @id @default(uuid())
  tenantId      String          @map("tenant_id")
  branchId      String?         @map("branch_id")
  categoryId    String          @map("category_id")
  title         String
  description   String?
  amount        Float
  date          DateTime
  paymentMethod String          @map("payment_method")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  category ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@map("expenses")
}

// ─── API Key (Integration) ──────────────────────────────

model ApiKey {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  branchId  String   @map("branch_id")
  name      String
  key       String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, isActive])
  @@map("api_keys")
}

// ─── Messaging ──────────────────────────────────────────

model Conversation {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  name        String?
  isGroup     Boolean   @default(false) @map("is_group")
  createdById String?   @map("created_by_id")
  workOrderId String?   @unique @map("work_order_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant       Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy    User?                     @relation("ConversationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  workOrder    WorkOrder?                @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id              String    @id @default(uuid())
  conversationId  String    @map("conversation_id")
  userId          String    @map("user_id")
  lastReadAt      DateTime? @map("last_read_at")
  clearedAt       DateTime? @map("cleared_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id              String   @id @default(uuid())
  conversationId  String   @map("conversation_id")
  senderId        String   @map("sender_id")
  content         String
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  conversation Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User               @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  readReceipts MessageReadReceipt[]

  @@index([conversationId, createdAt])
  @@map("messages")
}

model MessageReadReceipt {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  readAt    DateTime @default(now()) @map("read_at")

  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@map("message_read_receipts")
}
