// Dental Lab Management System — Core Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  OWNER
  ADMIN
  TECHNICIAN
  DELIVERY
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum WorkOrderStatus {
  CREATED
  ASSIGNED
  IN_PROGRESS
  INTERNAL_VERIFICATION
  EXTERNAL_VERIFICATION
  COMPLETED
  FAILED
  CANCELLED
}

enum ProcessStatus {
  NOT_STARTED
  IN_PROGRESS
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}


// ─── Tenant ──────────────────────────────────────────────

model Tenant {
  id          String       @id @default(uuid())
  name        String
  subdomain   String       @unique
  status      TenantStatus @default(ACTIVE)
  logoUrl     String?      @map("logo_url")
  contactEmail String?     @map("contact_email")
  contactPhone String?     @map("contact_phone")
  address     String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // Relations
  branches        Branch[]
  users           User[]
  settings        TenantSettings?
  doctors         Doctor[]
  prosthesisTypes ProsthesisType[]
  processes       Process[]
  workOrders      WorkOrder[]
  notifications   Notification[]
  auditLogs       AuditLog[]

  @@map("tenants")
}

model TenantSettings {
  id             String @id @default(uuid())
  tenantId       String @unique @map("tenant_id")
  timezone       String @default("UTC")
  dateFormat     String @default("DD/MM/YYYY") @map("date_format")
  currency       String @default("INR")
  workingDays    String @default("Mon,Tue,Wed,Thu,Fri,Sat") @map("working_days")
  workingHoursStart String @default("09:00") @map("working_hours_start")
  workingHoursEnd   String @default("18:00") @map("working_hours_end")
  features       Json   @default("{}")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

// ─── Branch ──────────────────────────────────────────────

model Branch {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  code        String
  address     String?
  phone       String?
  email       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users           User[]
  doctors         Doctor[]
  prosthesisTypes ProsthesisType[]
  processes       Process[]
  workOrders      WorkOrder[]

  @@unique([tenantId, code])
  @@map("branches")
}

// ─── User ────────────────────────────────────────────────

model User {
  id            String     @id @default(uuid())
  tenantId      String?    @map("tenant_id")
  branchId      String?    @map("branch_id")
  email         String
  passwordHash  String     @map("password_hash")
  firstName     String     @map("first_name")
  lastName      String     @map("last_name")
  phone         String?
  role          UserRole
  status        UserStatus @default(ACTIVE)
  avatarUrl     String?    @map("avatar_url")
  lastLoginAt   DateTime?  @map("last_login_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  // Relations
  tenant              Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch              Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  defaultTechnicianProcesses Process[]     @relation("ProcessDefaultTechnician")
  createdWorkOrders   WorkOrder[]          @relation("WorkOrderCreatedBy")
  assignedWoProcesses WorkOrderProcess[]   @relation("WoProcessTechnician")
  notifications       Notification[]

  @@unique([email, tenantId])
  @@map("users")
}

// ─── Refresh Token ───────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── Password Reset Token ────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─── Doctor ──────────────────────────────────────────────

model Doctor {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  branchId     String?  @map("branch_id")
  name         String
  clinicName   String?  @map("clinic_name")
  email        String?
  phone        String?
  address      String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  workOrders WorkOrder[]

  @@map("doctors")
}

// ─── Prosthesis Type ──────────────────────────────────────

model ProsthesisType {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  branchId    String?  @map("branch_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant             Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch             Branch?                 @relation(fields: [branchId], references: [id], onDelete: SetNull)
  processAssignments ProsthesisTypeProcess[]
  workOrders         WorkOrder[]

  @@unique([tenantId, branchId, name])
  @@map("prosthesis_types")
}

// ─── Process ─────────────────────────────────────────────

model Process {
  id                  String   @id @default(uuid())
  tenantId            String   @map("tenant_id")
  branchId            String?  @map("branch_id")
  name                String
  processArea         String   @map("process_area") // e.g. "Scanning", "Design", "Milling", "QC"
  defaultTechnicianId String   @map("default_technician_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  tenant                    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch                    Branch?                 @relation(fields: [branchId], references: [id], onDelete: SetNull)
  defaultTechnician         User                    @relation("ProcessDefaultTechnician", fields: [defaultTechnicianId], references: [id], onDelete: Cascade)
  prosthesisTypeAssignments ProsthesisTypeProcess[]

  @@map("processes")
}

// ─── Prosthesis Type ↔ Process (Junction) ────────────────

model ProsthesisTypeProcess {
  id               String   @id @default(uuid())
  prosthesisTypeId String   @map("prosthesis_type_id")
  processId        String   @map("process_id")
  sequence         Int      @default(0)
  createdAt        DateTime @default(now()) @map("created_at")

  // Relations
  prosthesisType ProsthesisType @relation(fields: [prosthesisTypeId], references: [id], onDelete: Cascade)
  process        Process        @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@unique([prosthesisTypeId, processId])
  @@map("prosthesis_type_processes")
}

// ─── Work Order ──────────────────────────────────────────

model WorkOrder {
  id               String          @id @default(uuid())
  tenantId         String          @map("tenant_id")
  branchId         String?         @map("branch_id")
  folioNumber      String          @map("folio_number")
  doctorId         String          @map("doctor_id")
  patient          String
  boxNumber        String?         @map("box_number")
  prosthesisTypeId String          @map("prosthesis_type_id")
  specification    String?
  notes            String?
  totalQuote       Float?          @map("total_quote")
  initialPayment   Float?          @map("initial_payment")
  status           WorkOrderStatus @default(CREATED)
  createdById      String          @map("created_by_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  // Relations
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  doctor         Doctor             @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  prosthesisType ProsthesisType     @relation(fields: [prosthesisTypeId], references: [id], onDelete: Cascade)
  createdBy      User               @relation("WorkOrderCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  processes      WorkOrderProcess[]

  @@unique([tenantId, folioNumber])
  @@map("work_orders")
}

// ─── Work Order Process ──────────────────────────────────

model WorkOrderProcess {
  id             String   @id @default(uuid())
  workOrderId    String   @map("work_order_id")
  processName    String   @map("process_name")
  technicianId   String?  @map("technician_id")
  sequence       Int      @default(0)
  isVerification Boolean       @default(false) @map("is_verification")
  status         ProcessStatus @default(NOT_STARTED)
  startedAt      DateTime?     @map("started_at")
  endedAt        DateTime?     @map("ended_at")
  lastPausedAt   DateTime?     @map("last_paused_at")
  pauseCount     Int           @default(0) @map("pause_count")
  totalPauseDuration Int       @default(0) @map("total_pause_duration")
  totalActiveDuration Int      @default(0) @map("total_active_duration")
  verificationStatus String?     @map("verification_status")
  createdAt      DateTime      @default(now()) @map("created_at")

  // Relations
  workOrder    WorkOrder            @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  technician   User?                @relation("WoProcessTechnician", fields: [technicianId], references: [id], onDelete: SetNull)
  activityLogs ProcessActivityLog[]

  @@map("work_order_processes")
}

enum ProcessActivityAction {
  START
  PAUSE
  RESUME
  END
}

model ProcessActivityLog {
  id                 String                @id @default(uuid())
  workOrderProcessId String                @map("work_order_process_id")
  action             ProcessActivityAction
  timestamp          DateTime              @default(now()) @map("timestamp")
  notes              String?               @map("notes")

  // Relations
  workOrderProcess   WorkOrderProcess      @relation(fields: [workOrderProcessId], references: [id], onDelete: Cascade)

  @@map("process_activity_logs")
}

// ─── Notification ────────────────────────────────────────

model Notification {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  userId      String   @map("user_id")
  title       String
  message     String
  type        String   @default("INFO")
  referenceId String?  @map("reference_id")
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── Audit Log ──────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  userId       String?  @map("user_id")
  userEmail    String?  @map("user_email")
  action       String
  entityName   String   @map("entity_name")
  entityId     String   @map("entity_id")
  details      String
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}
